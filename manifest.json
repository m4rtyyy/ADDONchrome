{
  "manifest_version": 3,
  "name": "ServiceNow → MyTime",
  "version": "3.0.0",
  "description": "Opens MyTime booking dialog when a TASK/CTASK is set to Closed Complete.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://*.service-now.com/*",
    "https://mytime.tietoevry.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.service-now.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://mytime.tietoevry.com/*"],
      "js": ["mytime.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
